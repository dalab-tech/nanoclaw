#!/usr/bin/env bash
# sup — NanoClaw remote diagnostics
# Usage: sup [target]         Live log tail
#        sup [target] --snap  Quick status snapshot
#   target: gcp (default) | oci

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TARGET="${1:-gcp}"
[[ "$TARGET" == "--snap" ]] && { TARGET="gcp"; SNAP=true; } || SNAP=false
[[ "${2:-}" == "--snap" ]] && SNAP=true

USER="anton"

# Build SSH command based on target
case "$TARGET" in
  gcp)
    INSTANCE=$(cd "$SCRIPT_DIR/infra/gcp" && pulumi stack output instanceName 2>/dev/null)
    ZONE=$(cd "$SCRIPT_DIR/infra/gcp" && pulumi config get nanoclaw:zone 2>/dev/null || echo "us-central1-a")
    if [ -z "$INSTANCE" ]; then
      echo "ERROR: could not resolve GCP instance name from Pulumi" >&2
      exit 1
    fi
    run_remote() { gcloud compute ssh "$INSTANCE" --zone="$ZONE" --tunnel-through-iap -- "$@"; }
    ;;
  oci)
    OCI_IP=$(cd "$SCRIPT_DIR/infra/oracle" && pulumi stack output publicIp 2>/dev/null || echo "129.146.4.124")
    run_remote() { ssh "$USER@$OCI_IP" "$@"; }
    ;;
  *)
    echo "Usage: sup [gcp|oci] [--snap]"
    exit 1
    ;;
esac

if $SNAP; then
  run_remote bash -s <<'SNAP'
    set -euo pipefail
    echo "=== Service Status ==="
    systemctl --user status nanoclaw --no-pager 2>/dev/null || echo "(service not found)"
    echo
    echo "=== Recent Logs ==="
    journalctl --user -u nanoclaw --no-pager -n 30 2>/dev/null || echo "(no logs)"
    echo
    echo "=== Active Containers ==="
    docker ps --filter name=nanoclaw- --format 'table {{.Names}}\t{{.Status}}\t{{.Command}}' 2>/dev/null || echo "(docker not available)"
    echo
    echo "=== Scheduled Tasks ==="
    if command -v sqlite3 &>/dev/null && [ -f ~/nanoclaw/store/messages.db ]; then
      sqlite3 ~/nanoclaw/store/messages.db "SELECT id, status, next_run FROM scheduled_tasks WHERE status='active' ORDER BY next_run LIMIT 10;"
    else
      echo "(sqlite3 not available or db not found)"
    fi
SNAP
else
  echo "Tailing NanoClaw logs on $TARGET (Ctrl+C to stop)..."
  run_remote journalctl --user -u nanoclaw -f --no-pager
fi
